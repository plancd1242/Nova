# 🤖 Nova basic settings
NOVA_NAME=Nova
NOVA_DEFAULT_USER=put_default_user_name_here
NOVA_CITY=put_city_here
NOVA_STATE=put_state_here
NOVA_COUNTRY=put_country_here
NOVA_TIMEZONE=put_timezone_here

# 🗣️ Voice settings
NOVA_ESPEAK_SPEED=140
NOVA_ESPEAK_PITCH=32

# 🌈 LED settings
NOVA_LED_COUNT=16
NOVA_LED_BRIGHTNESS=80
NOVA_LED_ENABLED=put_true_or_false

# 🔊 Volume control
NOVA_VOLUME_ENABLED=put_true_or_false
NOVA_VOLUME_HARDWARE_ENABLED=put_true_or_false
NOVA_VOLUME_DEFAULT=60
NOVA_VOLUME_MIN=0
NOVA_VOLUME_MAX=100
NOVA_ROTARY_MUTE_ENABLED=put_true_or_false
NOVA_VOLUME_ROTARY_STEP=2.5
NOVA_VOLUME_ROTARY_REVERSE=put_true_or_false

# 🌦️ Weather
OPENWEATHER_API_KEY=put_openweather_key_here

# 🔎 Tavily Search
TAVILY_API_KEY=put_tavily_key_here

# 🎵 Spotify
SPOTIFY_CLIENT_ID=put_client_id_here
SPOTIFY_CLIENT_SECRET=put_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/callback

# 🤖 Optional AI later
OPENAI_API_KEY=put_openai_key_here_if_used_later

# 🎤 Nova's Online & Offline Voice
ELEVENLABS_API_KEY=put_your_key_here
ELEVENLABS_VOICE_ID=put_voice_id_here
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
NOVA_OFFLINE_VOICE=en+f3
NOVA_OFFLINE_SPEED=140
NOVA_OFFLINE_PITCH=45

# 🖥️ OLED Pins
NOVA_OLED_ENABLED=put_true_or_false
NOVA_OLED_WIDTH=128
NOVA_OLED_HEIGHT=64
NOVA_OLED_REFRESH_SECONDS=5

# 🌡️ Temperature and humidity sensor
NOVA_CLIMATE_ENABLED=put_true_or_false
NOVA_CLIMATE_SENSOR_TYPE=DHT22

# 💡 Optional BH1750 light sensor
NOVA_LIGHT_ENABLED=put_true_or_false

# ⚡ Optional voltage sensor
NOVA_VOLTAGE_ENABLED=put_true_or_false
NOVA_VOLTAGE_CHANNEL=0
NOVA_VOLTAGE_SCALE=5.0

# 💾 Backup settings
NOVA_BACKUP_ENABLED=put_true_or_false
NOVA_BACKUP_TIME=00:00
NOVA_BACKUP_KEEP_DAYS=30

# 🚨 Lockdown
NOVA_LOCKDOWN_ENABLED=put_true_or_false
NOVA_LOCKDOWN_MOTION_ENABLED=put_true_or_false
NOVA_LOCKDOWN_CAMERA_ENABLED=put_true_or_false
NOVA_LOCKDOWN_ALERT_SOUND=put_sound_file_here_if_used

# 📷 Camera
NOVA_CAMERA_ENABLED=put_true_or_false

# 🚶 PIR motion sensor
NOVA_MOTION_ENABLED=put_true_or_false

# 👀 Ultrasonic sensor
NOVA_ULTRASONIC_ENABLED=put_true_or_false

# 😴 Sleep
NOVA_SLEEP_ENABLED=put_true_or_false
NOVA_SLEEP_OLED_DIM=put_true_or_false

# 🔔 Notifications
NOVA_NOTIFICATIONS_ENABLED=put_true_or_false
NOVA_NOTIFICATION_HISTORY_LIMIT=50

# 👤 Accounts
NOVA_ACCOUNTS_ENABLED=put_true_or_false

# 🎙️ Microphone and local voice login
NOVA_MICROPHONE_ENABLED=put_true_or_false
NOVA_VOICE_COMMANDS_ENABLED=put_true_or_false
NOVA_VOICE_INPUT_MODE=typed
NOVA_VOICE_WAKE_WORD_ENABLED=put_true_or_false
NOVA_VOICE_WAKE_WORDS=hey nova,nova
NOVA_VOICE_TRANSCRIPTION_ENGINE=vosk
NOVA_VOSK_MODEL_PATH=models/vosk-model-small-en-us-0.15
NOVA_AUDIO_INPUT_DEVICE=
NOVA_VOICE_SAMPLE_RATE=16000
NOVA_VOICE_RECORD_SECONDS=5
NOVA_VOICE_COMMAND_TIMEOUT_SECONDS=8
NOVA_VOICE_SILENCE_SECONDS=1.2
NOVA_VOICE_WAKE_COOLDOWN_SECONDS=2
NOVA_VOICE_LOGIN_ENABLED=put_true_or_false
NOVA_VOICE_PROFILE_DIR=data/voice_profiles
NOVA_VOICE_CONFIDENCE_THRESHOLD=0.82

# 📱 Nova PWA
NOVA_APP_HOST=127.0.0.1
NOVA_APP_PORT=8765
NOVA_APP_PASSWORD=put_strong_local_password_here

# 📶 TP-Link Router Control
NOVA_ROUTER_CONTROL_ENABLED=put_true_or_false
NOVA_ROUTER_AUTOMATION_ENGINE=playwright
NOVA_ROUTER_URL=put_local_router_url_here
NOVA_ROUTER_MODEL=put_router_model_here
NOVA_ROUTER_LOCAL_PASSWORD=put_local_router_password_here
NOVA_ROUTER_REQUIRE_ETHERNET=put_true_or_false
NOVA_ROUTER_REQUIRE_OFF_CONFIRMATION=put_true_or_false
NOVA_ROUTER_HEADLESS=put_true_or_false
NOVA_ROUTER_TIMEOUT_SECONDS=45
NOVA_ROUTER_DEBUG_SCREENSHOTS=put_true_or_false
NOVA_ROUTER_DEFAULT_SMART_CONNECT=put_true_or_false
NOVA_ROUTER_DEFAULT_OFDMA=put_true_or_false
NOVA_ROUTER_DEFAULT_MAIN_24=put_true_or_false
NOVA_ROUTER_DEFAULT_MAIN_5G1=put_true_or_false
NOVA_ROUTER_DEFAULT_MAIN_5G2=put_true_or_false

# 🍓 Hardware GPIO Pin Assignments
# Use board-style names such as D17 for CircuitPython modules where possible.
# Use BCM numbers for libraries that expect numeric GPIO pins, such as the LED ring.
NOVA_GPIO_OLED_SDA_PIN=put_gpio_pin_here
NOVA_GPIO_OLED_SCL_PIN=put_gpio_pin_here
NOVA_GPIO_OLED_I2C_ADDRESS=put_gpio_pin_here
NOVA_GPIO_LED_RING_PIN=put_gpio_pin_here
NOVA_GPIO_ROTARY_CLK_PIN=put_gpio_pin_here
NOVA_GPIO_ROTARY_DT_PIN=put_gpio_pin_here
NOVA_GPIO_ROTARY_SW_PIN=put_gpio_pin_here
NOVA_GPIO_DHT22_PIN=put_gpio_pin_here
NOVA_GPIO_PIR_PIN=put_gpio_pin_here
NOVA_GPIO_ULTRASONIC_TRIGGER_PIN=put_gpio_pin_here
NOVA_GPIO_ULTRASONIC_ECHO_PIN=put_gpio_pin_here
NOVA_GPIO_BH1750_SDA_PIN=put_gpio_pin_here
NOVA_GPIO_BH1750_SCL_PIN=put_gpio_pin_here
NOVA_GPIO_BH1750_I2C_ADDRESS=put_gpio_pin_here
NOVA_GPIO_CAMERA_CONNECTOR=put_gpio_pin_here
NOVA_GPIO_FUTURE_BUTTON_1_PIN=put_gpio_pin_here
NOVA_GPIO_FUTURE_BUTTON_2_PIN=put_gpio_pin_here
NOVA_GPIO_FUTURE_BUZZER_PIN=put_gpio_pin_here
NOVA_GPIO_FUTURE_RELAY_1_PIN=put_gpio_pin_here
NOVA_GPIO_FUTURE_SENSOR_1_PIN=put_gpio_pin_here
