# Nova basic settings
NOVA_NAME=Nova
NOVA_DEFAULT_USER=Caleb
NOVA_CITY=Metamora
NOVA_STATE=Michigan
NOVA_COUNTRY=US
NOVA_TIMEZONE=America/Detroit

# Voice settings
NOVA_ESPEAK_SPEED=140
NOVA_ESPEAK_PITCH=32

# LED settings
NOVA_LED_COUNT=12
NOVA_LED_PIN=18
NOVA_LED_BRIGHTNESS=80
NOVA_LED_ENABLED=false

# OLED settings
NOVA_OLED_ENABLED=false
NOVA_OLED_WIDTH=128
NOVA_OLED_HEIGHT=64
NOVA_OLED_I2C_ADDRESS=60
NOVA_OLED_REFRESH_SECONDS=5

# Temperature and humidity sensor
NOVA_CLIMATE_ENABLED=false
NOVA_CLIMATE_SENSOR_TYPE=DHT22
NOVA_CLIMATE_PIN=D17

# Weather
OPENWEATHER_API_KEY=put_your_openweather_api_key_here

# Google Search
GOOGLE_API_KEY=put_your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=put_search_engine_id_here

# Spotify
SPOTIFY_CLIENT_ID=put_your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=put_your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/callback

# Optional AI later
OPENAI_API_KEY=put_openai_key_here_if_used_later
